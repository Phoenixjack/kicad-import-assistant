    "common_pitches": {
      "P0.40": "0.40 mm",
      "P0.50": "0.50 mm",
      "P0.635": "0.635 mm / 0.025 in",
      "P0.80": "0.80 mm",
      "P1.00": "1.00 mm",
      "P1.25": "1.25 mm",
      "P1.27": "1.27 mm / 0.050 in",
      "P1.50": "1.50 mm",
      "P2.00": "2.00 mm",
      "P2.50": "2.50 mm",
      "P2.54": "2.54 mm / 0.100 in",
      "P3.50": "3.50 mm",
      "P3.81": "3.81 mm",
      "P5.00": "5.00 mm",
      "P5.08": "5.08 mm / 0.200 in"
    }
  },
  "normalization": {
    "space_replacement": "-",
    "omit_empty_optional_fields": true,
    "pitch": {
      "preferred_output_unit": "mm",
      "output_prefix": "P",
      "default_metric_decimal_places": 2,
      "allowed_metric_decimal_places": [
        2,
        3
      ],
      "allowed_inch_decimal_places": [
        3
      ],
      "accepted_metric_suffixes": [
        "mm"
      ],
      "accepted_inch_suffixes": [
        "in",
        "inch"
      ],
      "accepted_mil_suffixes": [
        "mil",
        "mils"
      ]
    }
  },
  "validation": {
    "pitch": {
      "metric_regex": "^P\\d+\\.\\d{2,3}$",
      "inch_input_regex": "^\\d+\\.\\d{3}(in|inch)$",
      "mil_input_regex": "^\\d+(\\.\\d+)?mils?$",
      "examples": [
        "P0.50",
        "P1.25",
        "P2.54",
        "P0.635"
      ]
    },
    "size": {
      "allowed_regex": [
        "^\\d+x\\d+$",
        "^\\d+P$",
        "^8P8C$"
      ],
      "examples": [
        "8",
		"14",
		"24",
		"1x06",
        "2x20",
        "24P",
        "8P8C"
      ]
    },
    "mpn": {
      "disallowed_characters": [
        "\\",
        "/",
        ":",
        "*",
        "?",
        "\"",
        "<",
        ">",
        "|"
      ],
      "space_replacement": "-"
    }
  }
}